{
  "manifest_version": 3,
  "name": "EchoNotes AI Companion",
  "description": "Quickly capture browser notes and sync them with EchoNotes AI.",
  "version": "1.0.0",
  "action": {
    "default_title": "EchoNotes AI Companion",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:5167/*",
    "http://localhost:3000/*",
    "https://*/*",
    "http://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*/*",
        "http://*/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
